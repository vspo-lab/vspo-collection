{
	"$schema": "https://turbo.build/schema.json",
	"globalDependencies": ["**/.env.*local"],
	"globalPassThroughEnv": ["GCP_PROJECT_ID", "GCP_LOCATION", "FRONTEND_URL"],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"],
			"cache": false
		},
		"type-check": {
			"dependsOn": ["^type-check"],
			"cache": false
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"test": {
			"cache": false
		},
		"biome:check": {
			"cache": false
		},
		"biome": {
			"cache": false
		},
		"//#knip": {
			"cache": false,
			"inputs": [
				"knip.json",
				"packages/*/package.json",
				"packages/*/*.ts",
				"services/*/src/**",
				"services/*/package.json"
			]
		},
		"//#knip:fix": {
			"cache": false
		}
	}
}
