{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":maintainLockFilesWeekly",
    "helpers:pinGitHubActionDigests",
    "local>sugar-cat7/vspo-search:renovate/groups/shared",
    "local>sugar-cat7/vspo-search:renovate/groups/web",
    "local>sugar-cat7/vspo-search:renovate/groups/api",
    "local>sugar-cat7/vspo-search:renovate/groups/infra"
  ],
  "labels": ["dependencies"],
  "timezone": "Asia/Tokyo",
  "schedule": ["after 9am and before 5pm on weekdays"],
  "prHourlyLimit": 3,
  "prConcurrentLimit": 10,
  "minimumReleaseAge": "3 days",
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "minimumReleaseAge": "0 days"
  },
  "pnpm": {
    "supportCatalog": true
  },
  "enabledManagers": ["npm", "dockerfile", "docker-compose", "terraform", "github-actions"]
}
