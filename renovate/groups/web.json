{
	"packageRules": [
		{
			"description": "Web service branch prefix",
			"matchFileNames": ["services/web/package.json"],
			"additionalBranchPrefix": "web-"
		},
		{
			"description": "React ecosystem",
			"groupName": "web-react",
			"matchPackagePatterns": ["^react$", "^react-dom$", "^@types/react"],
			"matchUpdateTypes": ["minor", "patch"]
		},
		{
			"description": "React major",
			"groupName": "web-react-major",
			"matchPackagePatterns": ["^react$", "^react-dom$", "^@types/react"],
			"matchUpdateTypes": ["major"]
		},
		{
			"description": "TanStack ecosystem",
			"groupName": "web-tanstack",
			"matchPackagePatterns": ["^@tanstack/"],
			"matchUpdateTypes": ["minor", "patch"],
			"automerge": true
		},
		{
			"description": "UI components (Radix, TailwindCSS, Lucide)",
			"groupName": "web-ui",
			"matchPackagePatterns": [
				"^@radix-ui/",
				"^tailwindcss$",
				"^@tailwindcss/",
				"^tailwind-merge$",
				"^lucide-react$",
				"^class-variance-authority$",
				"^clsx$"
			],
			"matchUpdateTypes": ["minor", "patch"],
			"automerge": true
		},
		{
			"description": "Storybook",
			"groupName": "web-storybook",
			"matchPackagePatterns": [
				"^storybook$",
				"^@storybook/",
				"^@chromatic-com/storybook$"
			],
			"matchUpdateTypes": ["minor", "patch"],
			"automerge": true
		},
		{
			"description": "E2E/Browser testing",
			"groupName": "web-e2e",
			"matchPackagePatterns": [
				"^@playwright/",
				"^@vitest/browser",
				"^msw$",
				"^msw-storybook-addon$"
			],
			"matchUpdateTypes": ["minor", "patch"],
			"automerge": true
		},
		{
			"description": "Vite",
			"groupName": "web-vite",
			"matchPackagePatterns": ["^vite$"],
			"matchUpdateTypes": ["minor", "patch"],
			"automerge": true
		}
	]
}
