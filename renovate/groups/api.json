{
  "packageRules": [
    {
      "description": "API service branch prefix",
      "matchFileNames": ["services/api/package.json"],
      "additionalBranchPrefix": "api-"
    },
    {
      "description": "Hono server ecosystem",
      "groupName": "api-hono",
      "matchPackagePatterns": ["^@hono/node-server$", "^@hono/swagger-ui$", "^@hono/zod-openapi$"],
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "description": "Drizzle ORM",
      "groupName": "api-drizzle",
      "matchPackagePatterns": ["^drizzle-orm$", "^drizzle-kit$", "^drizzle-zod$"],
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "description": "Database drivers",
      "groupName": "api-database",
      "matchPackagePatterns": ["^mysql2$", "^@tidbcloud/"],
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "description": "Firebase Admin",
      "groupName": "api-firebase-admin",
      "matchPackagePatterns": ["^firebase-admin$"],
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "description": "External services (Stripe, Resend)",
      "groupName": "api-services",
      "matchPackageNames": ["stripe", "resend"],
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "description": "TypeScript execution",
      "groupName": "api-tsx",
      "matchPackagePatterns": ["^tsx$"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    }
  ]
}
