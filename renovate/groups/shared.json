{
  "packageRules": [
    {
      "description": "Shared packages branch prefix",
      "matchFileNames": ["packages/*/package.json"],
      "additionalBranchPrefix": "packages-"
    },
    {
      "description": "Automerge minor/patch for dev dependencies",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Require approval for major updates",
      "matchUpdateTypes": ["major"],
      "labels": ["major-update", "requires-review"],
      "automerge": false
    },
    {
      "description": "Core shared: better-auth (web + api)",
      "groupName": "shared-auth",
      "matchPackagePatterns": ["^better-auth$"],
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "description": "Core shared: Hono (RPC client/server)",
      "groupName": "shared-hono",
      "matchPackagePatterns": ["^hono$"],
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "description": "Core shared: Zod",
      "groupName": "shared-zod",
      "matchPackagePatterns": ["^zod$"],
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "description": "Monorepo tooling",
      "groupName": "shared-monorepo",
      "matchPackageNames": ["turbo", "typescript", "tsup", "knip", "dotenv-cli"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "description": "Linting (Biome)",
      "groupName": "shared-linting",
      "matchPackagePatterns": ["^@biomejs/"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "description": "Testing (Vitest)",
      "groupName": "shared-testing",
      "matchPackagePatterns": ["^vitest$", "^@vitest/coverage"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "description": "Shared packages: tslog, dayjs",
      "groupName": "shared-libs",
      "matchPackagePatterns": ["^tslog$", "^dayjs$"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "description": "pnpm package manager",
      "matchPackageNames": ["pnpm"],
      "matchDepTypes": ["packageManager"],
      "labels": ["pnpm"],
      "automerge": false
    }
  ]
}
