{
	"$schema": "https://unpkg.com/knip@5/schema.json",
	"ignoreExportsUsedInFile": {
		"interface": true,
		"type": true
	},
	"tags": ["-lintignore"],
	"workspaces": {
		".": {
			"ignoreDependencies": ["@biomejs/biome"]
		},
		"services/web": {
			"entry": ["src/routes/**/*.{ts,tsx}"],
			"project": ["**/*.{ts,tsx}"],
			"ignore": [".tanstack/**", "node_modules/**"],
			"ignoreDependencies": ["tailwindcss"]
		},
		"packages/dayjs": {
			"project": ["*.ts"],
			"ignore": ["dist/**", "node_modules/**"]
		},
		"packages/errors": {
			"project": ["*.ts"],
			"ignore": ["dist/**", "node_modules/**"]
		},
		"packages/logger": {
			"project": ["*.ts"],
			"ignore": ["dist/**", "node_modules/**"]
		}
	}
}
